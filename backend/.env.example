# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dental-clinic?retryWrites=true&w=majority
# For local MongoDB: mongodb://127.0.0.1:27017/dental-clinic

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_make_it_strong

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_password_here

# Admin Credentials
ADMIN_EMAIL=admin@dentalclinic.com
ADMIN_PASSWORD=admin123

# Doctor Credentials (for appointment confirmation)
DOCTOR_EMAIL=doctor@dentalclinic.com
DOCTOR_PASSWORD=doctor123

# API Configuration
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
